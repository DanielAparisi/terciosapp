---
import Mail from "./mail.astro";
---
<footer id="Footer" style="border-top:1px solid var(--ink);padding:48px 0 24px;background:var(--bg);margin-top:80px;">
  <div style="max-width:1440px;margin:0 auto;padding:0 32px;">
    <div class="footer-top">
      <div>
        <div style="font-family:'Oswald',sans-serif;font-weight:700;text-transform:uppercase;font-size:clamp(40px,5vw,72px);line-height:0.9;color:var(--ink);">LOS<br>TERCIOS</div>
        <p style="margin-top:16px;font-size:14px;color:var(--muted);max-width:280px;line-height:1.6;">Equipo de fútbol sala y fútbol 7. IES Campiña Alta · Est. 2023</p>
      </div>
      <div>
        <h4 style="font-family:'Oswald',sans-serif;font-weight:600;text-transform:uppercase;font-size:13px;letter-spacing:0.1em;margin-bottom:16px;color:var(--muted);">Navegación</h4>
        <div style="display:flex;flex-direction:column;gap:4px;">
          <a href="#Equipaciones" style="font-size:14px;color:var(--ink);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--line);">Equipaciones</a>
          <a href="#Plantilla" style="font-size:14px;color:var(--ink);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--line);">Plantilla</a>
          <a href="#Historia" style="font-size:14px;color:var(--ink);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--line);">Historia</a>
        </div>
      </div>
      <div>
        <h4 style="font-family:'Oswald',sans-serif;font-weight:600;text-transform:uppercase;font-size:13px;letter-spacing:0.1em;margin-bottom:16px;color:var(--muted);">Legal</h4>
        <div style="display:flex;flex-direction:column;gap:4px;">
          <a href="#" style="font-size:14px;color:var(--ink);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--line);">Sobre</a>
          <a href="#" style="font-size:14px;color:var(--ink);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--line);">Políticas</a>
          <a href="#" style="font-size:14px;color:var(--ink);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--line);">Licencia</a>
        </div>
      </div>
      <div>
        <h4 style="font-family:'Oswald',sans-serif;font-weight:600;text-transform:uppercase;font-size:13px;letter-spacing:0.1em;margin-bottom:16px;color:var(--muted);">Síguenos</h4>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <a href="#" class="soc-link">
            <img src="/youtube-color.svg" alt="YouTube" style="width:18px;height:18px;object-fit:contain;" />
            <span>YouTube</span>
          </a>
          <a href="#" class="soc-link">
            <img src="/instagram-1.svg" alt="Instagram" style="width:18px;height:18px;object-fit:contain;" />
            <span>Instagram</span>
          </a>
          <a href="#" class="soc-link">
            <img src="/tiktok-color.svg" alt="TikTok" style="width:18px;height:18px;object-fit:contain;" />
            <span>TikTok</span>
          </a>
          <a href="#" class="soc-link">
            <img src="/spotify-color.svg" alt="Spotify" style="width:18px;height:18px;object-fit:contain;" />
            <span>Spotify</span>
          </a>
        </div>
      </div>
    </div>

    <div style="display:flex;justify-content:space-between;align-items:center;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);padding-top:24px;border-top:1px solid var(--line);flex-wrap:wrap;gap:12px;">
      <span>© 2025 Los Tercios FC · Todos los derechos reservados</span>
      <a href="#" style="color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:8px;">
        <Mail/>
        Contacto
      </a>
    </div>
  </div>
</footer>

<style>
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 32px;
  padding-bottom: 32px;
}

@media (max-width: 900px) {
  .footer-top {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 480px) {
  .footer-top {
    grid-template-columns: 1fr;
  }
}

.soc-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border: 1px solid var(--ink);
  background: var(--bg);
  text-decoration: none;
  color: var(--ink);
  font-family: 'Oswald', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  font-size: 13px;
  letter-spacing: 0.04em;
  transition: all 0.25s;
}

.soc-link:hover {
  background: var(--ink);
  color: var(--bg);
}

.soc-link:hover img {
  filter: invert(1) brightness(2);
}
</style>
