---
---
<header id="header" class="py-0 px-0 flex items-center fixed top-0 w-full justify-between z-40" style="background:var(--bg);border-bottom:1px solid var(--ink);height:64px;">
    <div class="nav-inner-wrap">
        <!-- Logo -->
        <a href="#" class="nav-logo">
            <img src="/tercioslogo.svg" alt="Los Tercios" style="height:32px;width:32px;object-fit:contain;" />
            <span>LOS&nbsp;TERCIOS</span>
        </a>

        <!-- Nav desktop -->
        <nav id="nav-menu" class="nav-links-desktop">
            <a href="#Equipaciones" onclick="closeMenu()">Equipaciones</a>
            <a href="#Plantilla" onclick="closeMenu()">Plantilla</a>
            <a href="#Historia" onclick="closeMenu()">Historia</a>
            <a href="#Patrocinadores" onclick="closeMenu()">Patrocinadores</a>
            <a href="#Footer" onclick="closeMenu()">Contáctanos</a>
        </nav>

        <!-- Right side -->
        <div class="nav-right-area">
            <div class="live-ticker">
                <span class="live-dot"></span>
                LIGA 2025·26
            </div>
            <!-- Hamburger -->
            <button
                class="hamburger-btn"
                aria-label="Abrir menú"
                id="menu-toggle"
            >
                <span class="ham-line" id="ham-1"></span>
                <span class="ham-line" id="ham-2"></span>
                <span class="ham-line" id="ham-3"></span>
            </button>
        </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="mobile-menu hidden">
        <a href="#Equipaciones" onclick="closeMenu()">Equipaciones</a>
        <a href="#Plantilla" onclick="closeMenu()">Plantilla</a>
        <a href="#Historia" onclick="closeMenu()">Historia</a>
        <a href="#Patrocinadores" onclick="closeMenu()">Patrocinadores</a>
        <a href="#Footer" onclick="closeMenu()">Contáctanos</a>
    </div>
</header>

<style>
.nav-inner-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 64px;
    padding: 0 32px;
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 18px;
    color: var(--ink);
    text-decoration: none;
}

.nav-links-desktop {
    display: none;
    gap: 28px;
}

@media (min-width: 768px) {
    .nav-links-desktop {
        display: flex;
    }
}

.nav-links-desktop a {
    font-family: 'Oswald', sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    position: relative;
    padding: 4px 0;
}

.nav-links-desktop a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s;
}

.nav-links-desktop a:hover::after {
    transform: scaleX(1);
}

.nav-right-area {
    display: flex;
    align-items: center;
    gap: 16px;
}

.live-ticker {
    display: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    align-items: center;
    gap: 8px;
    white-space: nowrap;
}

@media (min-width: 1100px) {
    .live-ticker {
        display: flex;
    }
}

.live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--red);
    box-shadow: 0 0 0 0 rgba(230, 57, 70, 0.6);
    animation: pulse 1.6s infinite;
    display: inline-block;
}

@keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(230, 57, 70, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(230, 57, 70, 0); }
    100% { box-shadow: 0 0 0 0 rgba(230, 57, 70, 0); }
}

.hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    gap: 5px;
    padding: 0;
}

@media (min-width: 768px) {
    .hamburger-btn {
        display: none;
    }
}

.ham-line {
    display: block;
    height: 1.5px;
    width: 24px;
    background: var(--ink);
    transition: all 0.3s;
}

.mobile-menu {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--ink);
    padding: 16px 32px;
    display: flex;
    flex-direction: column;
    gap: 0;
    z-index: 39;
}

.mobile-menu a {
    font-family: 'Oswald', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 15px;
    color: var(--ink);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
}

.mobile-menu a:last-child {
    border-bottom: none;
}

.hidden {
    display: none !important;
}
</style>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const ham1 = document.getElementById('ham-1');
    const ham2 = document.getElementById('ham-2');
    const ham3 = document.getElementById('ham-3');
    let menuOpen = false;

    function closeMenu() {
        menuOpen = false;
        mobileMenu?.classList.add('hidden');
        if (ham1 && ham2 && ham3) {
            ham1.style.transform = '';
            ham2.style.opacity = '1';
            ham3.style.transform = '';
        }
    }

    (window as any).closeMenu = closeMenu;

    if (menuToggle && mobileMenu) {
        menuToggle.addEventListener('click', () => {
            menuOpen = !menuOpen;
            if (menuOpen) {
                mobileMenu.classList.remove('hidden');
                if (ham1 && ham2 && ham3) {
                    ham1.style.transform = 'rotate(45deg) translate(4.5px, 4.5px)';
                    ham2.style.opacity = '0';
                    ham3.style.transform = 'rotate(-45deg) translate(4.5px, -4.5px)';
                }
            } else {
                closeMenu();
            }
        });
    }
</script>
