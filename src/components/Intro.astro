---

---
<section id="Intro" class="intro-section">
  <div class="intro-text">
    <div class="eyebrow eyebrow--red intro-eyebrow">Temporada 25 · 26 · Liga Local F7</div>
    <h1 class="intro-title">
      BIENVENIDOS<br>
      <span class="intro-title-red">LOS TERCIOS</span>
    </h1>
    <p class="intro-desc">
      Equipo de fútbol apasionados por el deporte, la amistad y la superación. Únete a nuestra comunidad y vive la pasión del fútbol con nosotros.
    </p>
    <div class="intro-actions">
      <a href="#Plantilla" class="btn-primary">Ver plantilla</a>
      <a href="#Historia" class="btn-ghost">Nuestra historia</a>
    </div>
  </div>

  <div class="intro-img-wrap">
    <img
      src="/ImagenTerciosMain.webp"
      alt="Equipo de fútbol Los Tercios"
      class="intro-img"
    />
  </div>
</section>

<style>
.intro-section {
  width: 100%;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

@media (min-width: 768px) {
  .intro-section {
    flex-direction: row;
    align-items: stretch;
  }
}

/* Text side */
.intro-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56px 24px 40px;
  text-align: center;
}

@media (min-width: 768px) {
  .intro-text {
    padding: 48px 40px;
    align-items: flex-start;
    text-align: left;
  }
}

@media (min-width: 1024px) {
  .intro-text {
    padding: 64px 64px;
  }
}

.intro-eyebrow {
  margin-bottom: 20px;
}

.intro-title {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: clamp(44px, 8vw, 120px);
  line-height: 0.88;
  text-transform: uppercase;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin: 0;
}

.intro-title-red {
  color: var(--red);
}

.intro-desc {
  margin-top: 24px;
  font-size: 15px;
  line-height: 1.65;
  color: var(--muted);
  max-width: 440px;
  margin-bottom: 0;
}

@media (min-width: 768px) {
  .intro-desc { font-size: 16px; }
}

.intro-actions {
  margin-top: 32px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
}

@media (min-width: 768px) {
  .intro-actions { justify-content: flex-start; }
}

/* Image side */
.intro-img-wrap {
  flex: 1;
  overflow: hidden;
  min-height: 300px;
}

@media (min-width: 768px) {
  .intro-img-wrap {
    min-height: unset;
  }
}

.intro-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Buttons */
.btn-primary {
  display: inline-flex;
  align-items: center;
  padding: 13px 22px;
  background: var(--red);
  border: 1px solid var(--red);
  color: #fff;
  font-family: 'Oswald', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 14px;
  text-decoration: none;
  transition: background 0.3s, border-color 0.3s;
}

.btn-primary:hover {
  background: var(--red-deep);
  border-color: var(--red-deep);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 13px 22px;
  background: transparent;
  border: 1px solid var(--ink);
  color: var(--ink);
  font-family: 'Oswald', sans-serif;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 14px;
  text-decoration: none;
  transition: background 0.3s, color 0.3s;
}

.btn-ghost:hover {
  background: var(--ink);
  color: var(--bg);
}
</style>
