---
import  { DEFENSAS, DELANTERO, MEDIOCENTRO, PORTERO, PRESIDENTE } from "../const/player.astro"
import PlayerCard from "./PlayerCard.astro"
---

<section id="Plantilla" style="padding:80px 0;background:var(--bg);">
  <div style="max-width:1440px;margin:0 auto;padding:0 32px;">
    <!-- Section header -->
    <div style="display:flex;align-items:flex-end;justify-content:space-between;padding-bottom:24px;border-bottom:1px solid var(--ink);margin-bottom:48px;gap:24px;">
      <h2 style="font-family:'Oswald',sans-serif;font-weight:700;font-size:clamp(56px,7vw,120px);text-transform:uppercase;line-height:0.88;color:var(--ink);">LA PLANTILLA</h2>
      <span class="eyebrow" style="padding-bottom:8px;">Temporada 25·26</span>
    </div>

    <!-- Portero -->
    <div style="margin-bottom:48px;">
      <div class="pos-label">Portero</div>
      <div class="players-row">
        {PORTERO.map(({id, name, role }) => (
          <PlayerCard id={id} name={name} role={role} />
        ))}
      </div>
    </div>

    <!-- Defensas -->
    <div style="margin-bottom:48px;">
      <div class="pos-label">Defensas</div>
      <div class="players-row">
        {DEFENSAS.map(({id, name, role="Defensa"}) => (
          <PlayerCard id={id} name={name} role={role} />
        ))}
      </div>
    </div>

    <!-- Mediocentros -->
    <div style="margin-bottom:48px;">
      <div class="pos-label">Mediocentros</div>
      <div class="players-row">
        {MEDIOCENTRO.map(({id, name, role="Mediocentro"}) => (
          <PlayerCard id={id} name={name} role={role} />
        ))}
      </div>
    </div>

    <!-- Delanteros -->
    <div style="margin-bottom:48px;">
      <div class="pos-label">Delanteros</div>
      <div class="players-row">
        {DELANTERO.map(({id, name, role}) => (
          <PlayerCard id={id} name={name} role={role} />
        ))}
      </div>
    </div>

    <!-- Presidente -->
    <div style="margin-bottom:16px;">
      <div class="pos-label">Presidente</div>
      <div class="players-row">
        {PRESIDENTE.map(({id, name, role}) => (
          <PlayerCard id={id} name={name} role={role} />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.pos-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--line);
}
.players-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-start;
}
</style>
