---
import Layout from "../layouts/Layout.astro";
import { JUGADORES, STATS } from "../const/player.ts";
import Groq from "groq-sdk";

export async function getStaticPaths() {
  const client = new Groq({ apiKey: import.meta.env.GROQ_API_KEY });

  const paths = await Promise.all(
    JUGADORES.map(async (player) => {
      let bio = "";
      try {
        const message = await client.chat.completions.create({
          model: "llama-3.3-70b-versatile",
          max_tokens: 200,
          messages: [
            {
              role: "user",
              content: `Genera una pequeña biografía deportiva de 2-3 frases para ${player.name}, ${player.role} del equipo de fútbol sala Los Tercios FC en la temporada 25/26. El texto debe ser en español, motivador y en tercera persona. Solo devuelve el texto, sin introducción ni formato extra.`,
            },
          ],
        });
        bio = message.choices[0]?.message?.content ?? "";
      } catch {
        bio = "";
      }
      const stats = STATS[player.id] ?? {
        partidos: 0,
        goles: 0,
        asistencias: 0,
        amarillas: 0,
        rojas: 0,
      };
      return {
        params: { id: player.id },
        props: { player, bio, stats },
      };
    }),
  );

  return paths;
}

const { player, bio, stats } = Astro.props;
---

<Layout
  title={player ? player.name : "Jugador"}
  description={player ? `Perfil de ${player.name}` : "Jugador no encontrado"}
>
  {
    player ? (
      <main class="player-page">
        <div class="player-page-inner">
          <div class="player-photo-col">
            <div class="player-photo-wrap">
              <img
                src={`/${player.id}.png`}
                alt={player.name}
                class="player-photo"
              />
            </div>
          </div>

          <div class="player-info-col">
            <div class="player-info-top">
              <span class="eyebrow eyebrow--red player-role">
                {player.role}
              </span>
              <h1 class="player-name">{player.name}</h1>
              <div class="player-meta-row">
                <span class="player-meta-item">
                  <span class="player-meta-label">Temporada</span>
                  <span class="player-meta-value">25·26</span>
                </span>
                <span class="player-meta-sep" />
                <span class="player-meta-item">
                  <span class="player-meta-label">Equipo</span>
                  <span class="player-meta-value">Los Tercios FC</span>
                </span>
                <span class="player-meta-sep" />
                <span class="player-meta-item">
                  <span class="player-meta-label">Posición</span>
                  <span class="player-meta-value">{player.role}</span>
                </span>
              </div>

              {bio && (
                <div class="player-bio">
                  <p class="player-bio-text">{bio}</p>
                  <span class="player-bio-badge">
                    <svg
                      width="10"
                      height="10"
                      viewBox="0 0 10 10"
                      fill="none"
                      aria-hidden="true"
                    >
                      <circle
                        cx="5"
                        cy="5"
                        r="4.5"
                        stroke="currentColor"
                        stroke-width="0.8"
                      />
                      <path
                        d="M3 5.5L4.5 7L7 3.5"
                        stroke="currentColor"
                        stroke-width="0.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    Generado por IA
                  </span>
                </div>
              )}
            </div>

            <div class="player-stats">
              <span class="player-stats-title">Temporada 25·26</span>
              <div class="stats-grid">
                <div class="stat-item">
                  <span class="stat-value">{stats.partidos}</span>
                  <span class="stat-label">Partidos</span>
                </div>
                <div class="stat-item">
                  <span class="stat-value">{stats.goles}</span>
                  <span class="stat-label">Goles</span>
                </div>
                <div class="stat-item">
                  <span class="stat-value">{stats.asistencias}</span>
                  <span class="stat-label">Asistencias</span>
                </div>
                <div class="stat-item stat-item--yellow">
                  <span class="stat-value">{stats.amarillas}</span>
                  <span class="stat-label">Amarillas</span>
                </div>
                <div class="stat-item stat-item--red">
                  <span class="stat-value">{stats.rojas}</span>
                  <span class="stat-label">Rojas</span>
                </div>
              </div>
            </div>

            <a href="/" class="back-btn">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M8.5 2L3.5 7L8.5 12"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              Volver a la plantilla
            </a>
          </div>
        </div>
      </main>
    ) : (
      <main class="not-found-page">
        <p>Jugador no encontrado.</p>
        <a href="/" class="back-btn">
          ← Volver
        </a>
      </main>
    )
  }
</Layout>

<style>
  /* Player page */
  .player-page {
    min-height: 100svh;
    background: var(--bg);
    display: flex;
    align-items: stretch;
  }

  .player-page-inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .player-page-inner {
      flex-direction: row;
    }
  }

  /* Photo column */
  .player-photo-col {
    flex: 1;
    background: var(--bg-2);
    border-right: 1px solid var(--line);
    overflow: hidden;
  }

  .player-photo-wrap {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .player-photo-wrap {
      aspect-ratio: unset;
      height: 100%;
      min-height: 100svh;
    }
  }

  .player-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Info column */
  .player-info-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 40px 24px;
    border-top: 1px solid var(--line);
  }

  @media (min-width: 768px) {
    .player-info-col {
      padding: 64px 48px;
      border-top: none;
      border-left: none;
    }
  }

  @media (min-width: 1024px) {
    .player-info-col {
      padding: 80px 64px;
    }
  }

  .player-info-top {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .player-role {
    margin-bottom: 16px;
    display: block;
  }

  .player-name {
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    font-size: clamp(40px, 6vw, 96px);
    text-transform: uppercase;
    line-height: 0.88;
    color: var(--ink);
    margin: 0 0 32px;
  }

  .player-meta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    flex-wrap: wrap;
  }

  .player-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .player-meta-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .player-meta-value {
    font-family: "Oswald", sans-serif;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  .player-meta-sep {
    width: 1px;
    height: 32px;
    background: var(--line);
    flex-shrink: 0;
  }

  /* Bio section */
  .player-bio {
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .player-bio-text {
    font-family: "Inter", sans-serif;
    font-weight: 300;
    font-size: clamp(14px, 1.2vw, 16px);
    line-height: 1.7;
    color: var(--ink-soft);
    margin: 0;
  }

  .player-bio-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    align-self: flex-start;
  }

  /* Stats */
  .player-stats {
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .player-stats-title {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .stats-grid {
    display: flex;
    gap: 0;
    border: 1px solid var(--line);
  }

  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 16px 8px;
    border-right: 1px solid var(--line);
  }

  .stat-item:last-child {
    border-right: none;
  }

  .stat-value {
    font-family: "Oswald", sans-serif;
    font-weight: 700;
    font-size: clamp(22px, 3vw, 32px);
    color: var(--ink);
    line-height: 1;
  }

  .stat-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
  }

  .stat-item--yellow .stat-value {
    color: #f0b429;
  }

  .stat-item--red .stat-value {
    color: var(--red);
  }

  /* Back button */
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    border: 1px solid var(--ink);
    background: transparent;
    color: var(--ink);
    font-family: "Oswald", sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 13px;
    text-decoration: none;
    transition:
      background 0.25s,
      color 0.25s;
    align-self: flex-start;
    margin-top: 40px;
  }

  .back-btn:hover {
    background: var(--ink);
    color: var(--bg);
  }

  /* Not found */
  .not-found-page {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 40px 20px;
  }
</style>
