---
interface  Props {
	description : string,
	title : string
}

const {description, title} = Astro.props

import Header from '../components/Header.astro'
import "../styles/global.css"

---
<!doctype html>
<html lang="es">
	<head>
      <link rel="icon" type="image/svg+xml" href="/favicon.svg">
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width" />
	  <meta name="description" content={description}>
      <title>{title}</title>
	</head>
	<body class="pt-16 sm:pt-16">
		<Header/>
    	<slot />
</body>
</html>
<style is:global>

:root {
  color-scheme: light;
}

html,
body {
	margin: 0;
	width: 100%;
	height: 100%;
	font-family: 'Inter', system-ui, sans-serif;
	scroll-behavior: smooth;
	background: var(--bg);
	color: var(--ink);
	box-sizing: border-box;
	padding: 0;
	border: 0 solid;
	overflow-x: hidden;
}

h1, h2, h3, h4, h5, h6 {
	font-family: 'Oswald', sans-serif;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: -0.01em;
	line-height: 0.92;
	color: var(--ink);
}

p {
	color: var(--ink-soft);
	line-height: 1.6;
	margin-bottom: 1em;
	font-weight: 400;
	font-size: 1em;
	letter-spacing: 0.01em;
}

p strong {
	color: var(--red);
	font-weight: 700;
}

strong {
	color: var(--red);
	font-weight: 700;
}

.section-rule {
	height: 1px;
	background: var(--ink);
	width: 100%;
}

.eyebrow {
	font-family: 'JetBrains Mono', monospace;
	font-size: 11px;
	letter-spacing: 0.24em;
	text-transform: uppercase;
	color: var(--muted);
}

.eyebrow--red {
	color: var(--red);
}

</style>

